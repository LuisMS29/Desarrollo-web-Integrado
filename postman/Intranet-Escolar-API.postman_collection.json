{
  "info": {
    "_postman_id": "intranet-escolar-2026",
    "name": "Intranet Escolar - API",
    "description": "Colección completa para probar la API de Intranet Escolar con JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 AUTENTICACIÓN",
      "item": [
        {
          "name": "1. Login (Obtener Token)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/auth/login", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "2. Obtener Perfil (Con Token)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:8080/api/auth/profile", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "profile"]}
          }
        },
        {
          "name": "3. Registrar Usuario",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"nuevoestudiante\",\n  \"email\": \"nuevo@alumno.edu.pe\",\n  \"password\": \"123456\",\n  \"rol\": \"ESTUDIANTE\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/auth/register", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "register"]}
          }
        }
      ]
    },
